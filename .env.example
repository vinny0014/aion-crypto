# ── AION Crypto — environment template (never commit real values) ──

# App (official project configuration)
APP_NAME="AION Crypto"
APP_SHORT_NAME=AIONCRYPTO
TAGLINE="Crypto Market Intelligence"
REPOSITORY=vinny0014/aion-crypto
DEPLOY_TARGET=Hostinger
APP_ENV=development                # development | production

# URLs — official production domain is https://aioncrypto.cloud (single canonical domain).
# In development/preview, override these with your local/preview URLs.
PUBLIC_SITE_URL=https://aioncrypto.cloud
CANONICAL_URL=https://aioncrypto.cloud
NEXT_PUBLIC_SITE_URL=https://aioncrypto.cloud   # dev: http://localhost:3000
FRONTEND_URL=http://localhost:3000              # prod: https://aioncrypto.cloud
BACKEND_URL=http://localhost:8000               # prod: backend URL behind aioncrypto.cloud

# Database (SQLite local only; PostgreSQL/Supabase in production)
DATABASE_URL=sqlite:///./aion_crypto_dev.db
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/aion_crypto

# Auth
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Market data (public endpoints — no keys required)
BINANCE_BASE_URL=https://api.binance.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
MARKET_CACHE_TTL_SECONDS=60

# Cost Guard
TOTAL_API_MONTHLY_LIMIT_USD=10

# Analytics (leave empty until configured — never use a fake ID)
VITE_GA_MEASUREMENT_ID=

# SMTP (newsletter — sending disabled until configured)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Paid AI APIs (optional; pipeline uses templates until configured)
ANTHROPIC_API_KEY=
