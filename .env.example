# ── AION Crypto — environment template (never commit real values) ──

# App
APP_NAME="AION Crypto"
APP_ENV=development                # development | production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Database (SQLite local only; PostgreSQL/Supabase in production)
DATABASE_URL=sqlite:///./aion_crypto_dev.db
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/aion_crypto

# Auth
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Market data (public endpoints — no keys required)
BINANCE_BASE_URL=https://api.binance.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
MARKET_CACHE_TTL_SECONDS=60

# Cost Guard
TOTAL_API_MONTHLY_LIMIT_USD=10

# Analytics (leave empty until configured — never use a fake ID)
VITE_GA_MEASUREMENT_ID=

# SMTP (newsletter — sending disabled until configured)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Paid AI APIs (optional; pipeline uses templates until configured)
ANTHROPIC_API_KEY=
